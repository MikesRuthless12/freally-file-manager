{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Copy That 2026",
  "version": "0.1.0",
  "identifier": "com.copythat.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Copy That 2026",
        "width": 1120,
        "height": 640,
        "minWidth": 960,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "UNTRUSTED_COMMENT_REPLACE_ME_WITH_RELEASE_PUBKEY",
      "endpoints": [
        "https://releases.copythat.app/{{channel}}/{{target}}-{{arch}}.json"
      ]
    }
  }
}
