{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Copy That v1.25.0",
  "version": "1.25.0",
  "identifier": "com.copythat.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Copy That v1.25.0",
        "width": 1120,
        "height": 640,
        "minWidth": 960,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "app", "dmg", "appimage", "deb", "rpm"],
    "createUpdaterArtifacts": false,
    "category": "Utility",
    "shortDescription": "Byte-exact cross-platform file copier.",
    "longDescription": "Copy That v1.25.0 is a lightweight, cross-platform, async, byte-exact file and folder copier. Matches every TeraCopy feature while staying as fast as — or faster than — Explorer, Finder, cp, and rsync for typical desktop workloads.",
    "homepage": "https://github.com/MikesRuthless12/CopyThat2026",
    "publisher": "Copy That Contributors",
    "copyright": "Copyright (C) 2026 Copy That Contributors",
    "licenseFile": "../../../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "allowDowngrades": true
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-",
      "hardenedRuntime": true
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"]
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3", "libayatana-appindicator-gtk3"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "UNTRUSTED_COMMENT_REPLACE_ME_WITH_RELEASE_PUBKEY",
      "endpoints": [
        "https://releases.copythat.app/{{channel}}/{{target}}-{{arch}}.json"
      ]
    }
  }
}
