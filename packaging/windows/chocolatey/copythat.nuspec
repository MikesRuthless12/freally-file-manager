<?xml version="1.0" encoding="utf-8"?>
<!-- Chocolatey community repository manifest. Free to publish; we use
     it as a secondary Windows channel (winget is primary). The MSI
     referenced from tools/chocolateyinstall.ps1 is the one produced
     by .github/workflows/release.yml, hashed at publish time. -->
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>copythat</id>
    <version>0.1.0</version>
    <title>Copy That 2026</title>
    <authors>Copy That 2026 Contributors</authors>
    <projectUrl>https://github.com/MikesRuthless12/CopyThat2026</projectUrl>
    <licenseUrl>https://github.com/MikesRuthless12/CopyThat2026/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <projectSourceUrl>https://github.com/MikesRuthless12/CopyThat2026</projectSourceUrl>
    <packageSourceUrl>https://github.com/MikesRuthless12/CopyThat2026/tree/main/packaging/windows/chocolatey</packageSourceUrl>
    <bugTrackerUrl>https://github.com/MikesRuthless12/CopyThat2026/issues</bugTrackerUrl>
    <docsUrl>https://github.com/MikesRuthless12/CopyThat2026#readme</docsUrl>
    <tags>copy file-copy teracopy verify rust tauri admin</tags>
    <summary>Byte-exact cross-platform file copier (Rust + Tauri 2).</summary>
    <description><![CDATA[
Copy That 2026 is a lightweight, cross-platform, async, byte-exact
file and folder copier. Matches every TeraCopy feature while staying
as fast as — or faster than — Explorer, Finder, cp, and rsync for
typical desktop workloads.

Features include:
- Verify after copy (CRC32 / MD5 / SHA-1/256/512 / xxHash3 / BLAKE3)
- Reflink clones on Btrfs / XFS / APFS / ReFS
- Shell integration (right-click → Copy with Copy That)
- SQLite history + totals dashboard
- Multi-pass secure delete
- 18-language UI

Ships unsigned; SmartScreen reputation clears the binary after
roughly 100 downloads.
]]></description>
    <releaseNotes>https://github.com/MikesRuthless12/CopyThat2026/releases/tag/v0.1.0</releaseNotes>
    <iconUrl>https://raw.githubusercontent.com/MikesRuthless12/CopyThat2026/main/apps/copythat-ui/src-tauri/icons/128x128.png</iconUrl>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
