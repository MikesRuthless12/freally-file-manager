<?xml version="1.0" encoding="UTF-8"?>
<!--
  Info.plist for the Freally File Manager v1.0.0 Finder Sync Extension.

  This file defines the .appex bundle that macOS Finder loads when
  the main app is installed. The principal class is resolved by
  name via the NSExtensionPrincipalClass key; @objc(FreallyFinderSync)
  in the Swift source exposes the matching Objective-C runtime
  name.

  Bundle layout on disk (produced by packaging/macos/scripts/bundle-appex.sh):

    FreallyFinderSync.appex/
      Contents/
        Info.plist                    (this file)
        MacOS/
          FreallyFinderSync          (Mach-O bundle exec)

  The .appex sits inside the main app bundle:

    Freally File Manager v1.0.0.app/
      Contents/
        PlugIns/
          FreallyFinderSync.appex/
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>

    <key>CFBundleDisplayName</key>
    <string>Freally File Manager Finder Sync</string>

    <key>CFBundleExecutable</key>
    <string>FreallyFinderSync</string>

    <key>CFBundleIdentifier</key>
    <string>com.freally.filemanager.FinderSync</string>

    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>

    <key>CFBundleName</key>
    <string>FreallyFinderSync</string>

    <key>CFBundlePackageType</key>
    <string>XPC!</string>

    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>LSMinimumSystemVersion</key>
    <string>12.0</string>

    <key>NSHumanReadableCopyright</key>
    <string>Copyright (c) 2026 Mike Weaver. All rights reserved.</string>

    <key>NSExtension</key>
    <dict>
        <key>NSExtensionPointIdentifier</key>
        <string>com.apple.FinderSync</string>
        <key>NSExtensionPrincipalClass</key>
        <string>FreallyFinderSync</string>
    </dict>
</dict>
</plist>
