Exec=freally %F
Icon=freally
Terminal=false
Categories=Utility;FileTools;FileManager;
MimeType=inode/directory;application/octet-stream;
Actions=Copy;Move;
Keywords=copy;move;verify;checksum;tera;

# Per-Phase-7 rule: these two Desktop Actions expose the shell-
# integration verbs. The file manager renders them as sub-entries
# under the application; right-clicking on files/folders with the
# `MimeType` above will offer them via the MIME system.

[Desktop Action Copy]
Name=Copy with Freally File Manager
