# --- Rust ---
target/
**/*.rs.bk
*.pdb
# Cargo.lock IS committed at the workspace root (binary workspace).

# --- Tauri ---
apps/copythat-ui/src-tauri/target/
apps/copythat-ui/src-tauri/gen/
.tauri/

# --- Node / pnpm / Vite ---
node_modules/
dist/
.vite/
.parcel-cache/
.pnpm-store/

# --- Logs and runtime data ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS noise ---
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# --- Editor / IDE ---
.vscode/
.idea/
*.iml
*.swp
*.swo
.history/

# --- Local secrets / env ---
.env
.env.local
.env.*.local

# --- Claude Code (per-user, not team-shared) ---
.claude/settings.local.json
.claude/scheduled_tasks.lock

# --- Test artifacts ---
coverage/
*.profraw
# Nautilus smoke test runs `python3 -m py_compile` against the
# packaged extension, which drops a __pycache__/ next to the source.
**/__pycache__/
*.pyc

# --- Generated tauri assets we don't want in git ---
apps/copythat-ui/src-tauri/Cargo.lock

# --- Strategic docs kept local-only per IP policy ---
# These files stay on disk for in-session reference but are never
# tracked by git. README.md and docs/SECURITY.md are deliberately
# NOT listed here (README.md is rendered by GitHub; SECURITY.md is
# the repo's security-disclosure policy).
/CopyThat2026-Build-Prompts-Guide.md
/docs/ARCHITECTURE.md
/docs/CHANGELOG.md
/docs/I18N_TODO.md
/docs/ROADMAP.md
/packaging/linux/README.md

# --- Icon workshop scratch output ---
# Per-iteration icon previews (rasterised SVG exports, pre-review
# renders, etc.) live under `/icon-previews/` and are not tracked.
# The approved deliverables live under `/icon/` and ARE tracked.
/icon-previews/
